# Admin console login (bootstrap user)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-production

# Public URL users and JWTs use (must match Cloudflare / ingress hostname)
KC_HOSTNAME=https://auth.dental-care.me

# Behind Cloudflare Tunnel or reverse proxy
KC_PROXY_HEADERS=xforwarded

# Host port mapped to Keycloak 8080
KEYCLOAK_HTTP_PORT=8080

# --- Local dev (no tunnel) — uncomment and use in docker compose ---
# KC_HOSTNAME=localhost:8080
# KC_PROXY_HEADERS=
