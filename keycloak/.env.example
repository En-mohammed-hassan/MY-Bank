# =============================================================================
# Keycloak container only (keycloak/docker-compose.yml)
# =============================================================================
# Old monolithic compose had postgres + keycloak + account-service in one file.
# This folder runs Keycloak only — other vars moved to b-user/ or k8s/.
# See "Migration" section at the bottom.

# Admin console login (bootstrap user)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-production

# Public URL users and JWTs use (must match what apps expect in iss claim)
# Local dev:
KC_HOSTNAME=localhost:8080
KC_PROXY_HEADERS=
# Production / Cloudflare Tunnel:
# KC_HOSTNAME=https://auth.dental-care.me
# KC_PROXY_HEADERS=xforwarded

# Host port mapped to Keycloak 8080
KEYCLOAK_HTTP_PORT=8080

# Image: docker-compose uses keycloak/keycloak (Docker Hub).
# If pull fails, try: docker pull keycloak/keycloak:26.0

# =============================================================================
# Migration — old single .env → where each variable lives now
# =============================================================================
#
# POSTGRES_USER=bank              → b-user/docker-compose.yml (bank_users DB)
# POSTGRES_PASSWORD=bank123       → b-user/docker-compose.yml
# POSTGRES_DB=bankdb              → now bank_users (see b-user/.env.example)
#
# KEYCLOAK_ADMIN                  → here (same)
# KEYCLOAK_ADMIN_PASSWORD         → here (same)
# KEYCLOAK_HTTP_PORT              → here (same)
#
# KEYCLOAK_ISSUER                 → b-user: KEYCLOAK_SERVER_URL + KEYCLOAK_REALM
#                                   (issuer = http://localhost:8080/realms/bank)
# KEYCLOAK_INTERNAL_ISSUER        → b-user: KEYCLOAK_INTERNAL_URL + realm
# KEYCLOAK_CLIENT_ID=bank-api     → b-user: KEYCLOAK_AUDIENCE=bank-api
