DATABASE_URL=postgresql+psycopg2://core:core@postgres:5432/core_banking
APP_PORT=8001

# Set true for local docker-compose without Keycloak
AUTH_DISABLED=true

KEYCLOAK_SERVER_URL=https://auth.dental-care.me
KEYCLOAK_REALM=bank
KEYCLOAK_PUBLIC_CLIENT_ID=bank-web
KEYCLOAK_JWKS_URL=https://auth.dental-care.me/realms/bank/protocol/openid-connect/certs
# KEYCLOAK_AUDIENCE=bank-api

# Set false in production (k8s). Local docker-compose defaults to true.
AUTH_DISABLED=true

KEYCLOAK_SERVER_URL=https://auth.dental-care.me
KEYCLOAK_REALM=bank
KEYCLOAK_PUBLIC_CLIENT_ID=bank-web
KEYCLOAK_JWKS_URL=https://auth.dental-care.me/realms/bank/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=bank-api
