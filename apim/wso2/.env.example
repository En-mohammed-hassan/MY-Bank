# WSO2 APIM hostnames (edit apim/wso2/conf/deployment.toml to match)
# Local Docker: keep localhost. Production gateway: api.dental-care.me
WSO2_HOSTNAME=localhost

# Backend service URLs — set in Publisher when creating APIs
CORE_BANKING_BACKEND_URL=https://core-api.dental-care.me
BANK_USER_BACKEND_URL=https://users-api.dental-care.me

# Local backends (direct service, bypassing k8s ingress)
# CORE_BANKING_BACKEND_URL=http://host.docker.internal:8001
# BANK_USER_BACKEND_URL=http://host.docker.internal:8002

# Keycloak (external authorization server for OAuth2 in Publisher)
KEYCLOAK_SERVER_URL=https://auth.dental-care.me
KEYCLOAK_REALM=bank
KEYCLOAK_TOKEN_URL=https://auth.dental-care.me/realms/bank/protocol/openid-connect/token
KEYCLOAK_JWKS_URL=https://auth.dental-care.me/realms/bank/protocol/openid-connect/certs

# OAuth2 client for gateway (create in Keycloak — see apim/README.md)
KEYCLOAK_GATEWAY_CLIENT_ID=bank-api
